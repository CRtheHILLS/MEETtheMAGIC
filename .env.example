# Copy this file to ".env" and fill in your own key.
#   cp .env.example .env

# Required: your OpenAI API key (needs Realtime API access)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Models (defaults shown — override if you like)
TRANSCRIBE_MODEL=gpt-4o-transcribe
TRANSLATE_MODEL=gpt-4.1-nano
COPILOT_MODEL=gpt-4.1-mini

# Optional: backup STT provider (not used by default)
# ELEVENLABS_API_KEY=your-elevenlabs-key-here
